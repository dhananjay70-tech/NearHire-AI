# ==========================================
# NearHire.AI — Comprehensive .gitignore
# ==========================================

# ─── Environment Files & Secrets ───
.env
.env.*
!.env.example
*.env

# ─── Node.js & Frontend Dependencies ───
node_modules/
jspm_packages/
.pnpm-store/

# ─── Build & Distribution Output ───
dist/
dist-ssr/
build/
out/
*.bundle.js
*.chunk.js

# ─── Logs & Runtime Data ───
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*
logs/
*.log.*

# ─── Python & Virtual Environments ───
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
ENV/
env.bak/
venv.bak/
pip-log.txt
pip-delete-this-directory.txt
.venv*/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ─── Testing & Coverage Reports ───
coverage/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.hypothesis/
.nox/
.tox/

# ─── Uploads & User Temp Files ───
uploads/
temp/
tmp/
*.tmp

# ─── Database & SQLite Files ───
*.sqlite
*.sqlite3
*.db
*.db-journal

# ─── IDE & Text Editors ───
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.suo
*.user
*.swp
*.swo
.project
.classpath
.settings/

# ─── OS Generated Files ───
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
[Dd]esktop.ini

# ─── AI & IDE Agent Folders ───
.gemini/
.antigravity/
.antigravity-ide/
.claude/
.cursor/

# ─── Caches & Tool Outputs ───
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.turbo/
