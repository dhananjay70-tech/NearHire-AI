# =====================================================
# NearHire Job Scraper — Environment (copy to .env)
# Every API key is OPTIONAL. A source with no key is skipped
# automatically; the service never fabricates jobs.
# =====================================================

# ── Service ──────────────────────────────────────────
HOST=0.0.0.0
PORT=8100
ENV=development
LOG_LEVEL=INFO

# ── Search defaults ──────────────────────────────────
DEFAULT_QUERY=software developer
DEFAULT_LOCATION=India
DEFAULT_COUNTRY=India
MAX_JOBS_PER_PROVIDER=30

# ── India-only mode ──────────────────────────────────
# true = drop every job not located in India (regardless of source).
INDIA_ONLY=true
# true = also keep worldwide/remote jobs that don't mention India.
# false (default) = strictly India-located jobs only.
INCLUDE_WORLDWIDE_REMOTE=false

# ── Provider API keys (all optional) ─────────────────
# JSearch (RapidAPI) — https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_API_KEY=

# Generic RapidAPI jobs endpoint (defaults to Active Jobs DB)
RAPIDAPI_KEY=
RAPIDAPI_JOBS_HOST=active-jobs-db.p.rapidapi.com
RAPIDAPI_JOBS_PATH=/active-ats-7d
RAPIDAPI_RESULTS_KEY=

# Adzuna — https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=in

# Jooble — https://jooble.org/api/about
JOOBLE_API_KEY=

# USAJobs — https://developer.usajobs.gov/ (optional)
USAJOBS_API_KEY=
USAJOBS_EMAIL=

# ── ATS boards (no key needed) ───────────────────────
GREENHOUSE_BOARDS=vercel,figma,stripe,airtable,dropbox
LEVER_BOARDS=netflix,spotify,plaid,ramp

# ── Company career pages scraper (optional) ──────────
# Comma-separated career-page URLs to crawl for job links.
COMPANY_CAREER_URLS=

# ── HTTP behaviour ───────────────────────────────────
HTTP_TIMEOUT=15
HTTP_MAX_RETRIES=3
HTTP_RETRY_BACKOFF=0.75
RATE_LIMIT_DELAY=0.4

# ── Feature toggles ──────────────────────────────────
ENABLE_SCRAPERS=true
ENABLE_SCHEDULER=true
SCHEDULER_INTERVAL_MINUTES=30
ENABLE_PLAYWRIGHT=false

# ── Cache (Redis optional; in-memory fallback if empty) ─
REDIS_URL=
CACHE_TTL_SECONDS=1800

# ── Geocoding ────────────────────────────────────────
ENABLE_NOMINATIM=true
NOMINATIM_USER_AGENT=NearHireJobScraper/1.0 (+https://nearhire.ai)

# ── Optional Postgres persistence (independent DB; OFF if empty) ─
# NOTE: use a SEPARATE database from the main backend.
DATABASE_URL=
