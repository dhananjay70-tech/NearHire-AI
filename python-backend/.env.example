# =====================================================
# Python Backend — Environment Configuration
# Copy this file to .env and fill in real values
# =====================================================

# Server
HOST=0.0.0.0
PORT=8000
ENV=development

# CORS — Frontend URL
CLIENT_URL=http://localhost:5173

# Node backend URL (for inter-service calls)
NODE_BACKEND_URL=http://localhost:5001/api

# Job Scraper microservice (MS3) — never hardcode; read from env.
JOB_SCRAPER_URL=http://localhost:8100

# JWT — MUST match the Node backend JWT_SECRET exactly
JWT_SECRET=use_the_same_secret_as_node_backend

# Google Gemini (optional — core features work without it)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

