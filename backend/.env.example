# =====================================================
# Node Backend — Environment Configuration
# Copy this file to .env and fill in real values
# =====================================================

PORT=5001
NODE_ENV=development

# PostgreSQL connection string (Supabase)
# Format: postgresql://<username>:<password>@<host>:<port>/<database>
DATABASE_URL="postgresql://postgres.rjpaznyszzivhmvnyzfr:Dhananjaykr70@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres"

# JWT secret — use a long random string (32+ characters)
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Frontend URL (used for CORS)
CLIENT_URL=http://localhost:5173

# Job Scraper microservice (MS3) base URL — never hardcode in code.
JOB_SCRAPER_URL=http://localhost:8100

# AWS SES Configurations (Deprecated)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
SES_FROM_EMAIL=your_verified_ses_email@example.com
AWS_SES_MOCK=true

# Brevo SMTP API Configurations
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=your_verified_brevo_sender_email@example.com
BREVO_SENDER_NAME="NearHire.AI"

# =====================================================
# Job Aggregation — External Source API Keys (all OPTIONAL)
# Sources without a key are simply skipped; the pipeline
# never breaks if a key is missing. RemoteOK/Greenhouse/Lever/
# Arbeitnow/Remotive/WWR need no keys and always run.
# =====================================================

# Adzuna Jobs API — https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=in

# JSearch via RapidAPI (aggregates LinkedIn/Indeed/Glassdoor)
# https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=

# Jooble Jobs API — https://jooble.org/api/about
JOOBLE_API_KEY=
JOOBLE_LOCATION=India

# =====================================================
# Scheduler & Caching
# =====================================================

# Scraper cron (default: every 30 minutes). Standard cron syntax.
SCRAPER_CRON=*/30 * * * *

# Optional Redis for job API caching. If unset, an in-memory
# TTL cache is used automatically (no Redis required).
# To enable Redis: set REDIS_URL and run `npm i ioredis`.
REDIS_URL=
CACHE_TTL_SECONDS=1800

# =====================================================
# Geocoding (city name -> lat/lng for radius search)
# =====================================================
# OpenStreetMap Nominatim requires an identifying User-Agent per their usage
# policy. Common Indian cities resolve instantly from a built-in table with no
# network call; only unlisted cities hit Nominatim. Put a real contact in prod.
NOMINATIM_USER_AGENT=NearHire.AI/1.0 (job-search)
